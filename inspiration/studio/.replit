
modules = ["nodejs-20", "web", "bash", "postgresql-16"]

[agent]
expertMode = true
integrations = ["javascript_openai_ai_integrations:2.0.0"]

[nix]
channel = "stable-25_05"
packages = ["vim-full", "gut"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Canvas Assistant API"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run vitedev"
waitForPort = 5000

[[workflows.workflow]]
name = "Canvas Assistant API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node server/canvas-assistant-api.js"
waitForPort = 3003

[[ports]]
localPort = 3000
externalPort = 3001

[[ports]]
localPort = 3001
externalPort = 3002

[[ports]]
localPort = 3002
externalPort = 3002

[[ports]]
localPort = 3003
externalPort = 3003

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 4200

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "vitebuild"]
publicDir = "dist"
run = ["node", "server/production-server.js"]

[userenv]

[userenv.shared]
VITE_CARDS_PER_ROW = "2"
API_PORT = "3001"
