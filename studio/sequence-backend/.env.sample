# ===========================================
# Sequence Backend - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.sample .env

# -------------------------------------------
# Required
# -------------------------------------------

# PostgreSQL connection string (required)
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://postgres:password@localhost:5432/sequence_db

# -------------------------------------------
# Server
# -------------------------------------------

# Port for the backend server (default: 3002)
SEQUENCE_PORT=3002

# Node environment: development | production
NODE_ENV=development

# -------------------------------------------
# Database (optional - DATABASE_URL takes precedence)
# -------------------------------------------

# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=password
# PGDATABASE=sequence_db

# -------------------------------------------
# Scheduler
# -------------------------------------------

# Poll interval for the scheduler in milliseconds (default: 10000)
# SCHEDULER_POLL_INTERVAL_MS=10000

# -------------------------------------------
# Logging
# -------------------------------------------

# Log level: info | debug | warn | error (default: info)
# LOG_LEVEL=info

# Slow query threshold in ms - queries slower than this are logged (default: 100)
# LOG_SLOW_QUERY_THRESHOLD_MS=100

# -------------------------------------------
# AI Formula (optional - for /api/ai-formula endpoints)
# -------------------------------------------

# OpenAI API key - required for AI formula generation
# AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
# OPEN_AI_KEY=sk-...

# Custom OpenAI API base URL (optional, for Azure OpenAI or other compatible APIs)
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
